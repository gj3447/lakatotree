; 라카토트리 엔진 계층 — strict layers 강제 (engine.py straddle 제거 후 승격, 2026-06-18).
; THEORY.md 엄격도 스택을 파일구조+import 로 못 박는다. foundation/shell(engine·verdicts·grounding·
; trust·claim·world_gates·harness*·longinus·cli·mcp_server·eureka)는 root 공유층(계약 대상 아님).
; engine.py 는 이제 순수 foundation(io/quant import 0): LineageReplay* → io/replay.py, trust → root.

[importlinter]
include_external_packages = True
root_packages =
    lakatos
    server
    c1verify

[importlinter:contract:engine-layers]
name = engine layers: programme > verdict > quant > io (no upward import)
type = layers
layers =
    lakatos.programme
    lakatos.verdict
    lakatos.quant
    lakatos.io
; (구 eureka 면제 제거: 아키텍처 감사 2026-06-26, finding D3/eureka) — eureka 가 promotion_gate 를 *주입*으로
; 받게 바뀌어(verdict.promote module-level import 제거) quant.metrics→eureka→verdict.promote 상향 체인이
; 소멸했다. 이제 layers 계약은 *예외-제로*다(ignore_imports 불필요). dead-weight carve-out 1줄 삭제.

; ── 서버 구조도 도구로 동결 (아키텍처 감사 2026-06-26, finding D6/F2) ──────────────────
; 엔진 계층은 위에서 기계검증되는데 더 크고 churn 많은 server/(DDD 바운디드 컨텍스트 + 헥사고날)는
; 여태 *규율로만* 유지됐다(import-linter 계약 0). 두 계약으로 오늘의 구조를 회귀로부터 못 박는다:
;  (1) tree ⊥ lineage  : 두 바운디드 컨텍스트는 서로 import 금지(공유 커널=lakatos.Derivation 으로만 통합).
;  (2) contexts ↛ adapters : 컨텍스트 서비스는 concrete 드라이버(mongo/neo4j) import 금지 —
;      adapters 는 합성 루트(app.py/container.py)만 만진다(DIP: 안쪽은 추상에만 의존).
[importlinter:contract:server-context-independence]
name = server bounded contexts: tree ⊥ lineage (no cross-context import)
type = independence
modules =
    server.contexts.tree
    server.contexts.lineage

[importlinter:contract:server-contexts-no-adapters]
name = server contexts must not import concrete adapters (only the composition root may)
type = forbidden
source_modules =
    server.contexts.tree
    server.contexts.lineage
forbidden_modules =
    server.adapters.mongo
    server.adapters.neo4j

; ── 엔진 ⊥ examples: 도구는 콘텐츠에 의존하지 않는다 (2026-07-03) ────────────────────
; "가지 늘리는데 왜 엔진 repo 를 건드리냐"의 정신모델을 계약으로 못 박는다: examples/(연구
; 프로그램·콘텐츠)는 엔진(lakatos/·server/)을 *쓰지만*, 엔진은 examples 를 절대 import 하지
; 않는다 = 방향성 경계. 위반 시 pip-설치 엔진(examples 없음)에서 크래시(cli.py:longinus
; --dashboard 가 실제로 그랬다 → longinus_dashboard 를 엔진으로 이관해 봉합). include_external_
; packages=True 라 examples 가 root 밖이어도 이 forbidden edge 를 grimp 이 본다(revert 로 검증).
[importlinter:contract:engine-independent-of-examples]
name = engine (lakatos, server) must not import examples (tool ⊥ content, directional boundary)
type = forbidden
source_modules =
    lakatos
    server
forbidden_modules =
    examples

; ── c1verify ⊥ 엔진: 외부 검증자 독립 (campaign C1, S0/P0b) ─────────────────────────────
; c1verify 는 엔진을 전혀 신뢰하지 않는 외부인의 검증자다 — lakatos/server 를 절대 import 하지
; 않는다(신뢰기반 = sha256+Ed25519 재구현, stdlib only). 이 forbidden edge 는 엔진-독립을 *구성
; 사실*로 못 박는 세 축 중 하나(나머지: clean-venv CI 잡 c1verify-standalone, subprocess sys.modules
; 가드). 엔진 순수함수의 copy-fidelity 는 engine-repo CI 의 out-of-band 골든 교차검증이 담당(패키지
; 밖). 위반(어디서든 import lakatos)하면 lint-imports 가 RED + clean-venv 잡이 ImportError.
[importlinter:contract:c1verify-standalone]
name = c1verify (external certificate verifier) must not import the engine (lakatos, server)
type = forbidden
source_modules =
    c1verify
forbidden_modules =
    lakatos
    server

      "output_type": "FeatureObservation list",
      "acceptance": "mask observations are location priors and never replace geometry measurement"
    },
    {
      "name": "CT_BPC_Hole3ClassVoidBoundary",
      "target_file": "services/inspection/src/adapters/bpc/detect_registry.py",
      "input_type": "hole class mask plus registered XYZ",
      "output_type": "center_xy and parent_or_base_z",
      "acceptance": "plate outer external holes do not report independent object z"
    },
    {
      "name": "CT_BPC_CupGeometry",
      "target_file": "services/inspection/src/adapters/bpc/detect_registry.py",
      "input_type": "cup mask plus registered XYZ and CAD truth",
      "output_type": "cup rings z and defect flags",
      "acceptance": "nadir-only z and BIG_02/BIG_09 defect flag preserved"
    },
    {
      "name": "CT_BPC_TabBoltWasherGeometry",
      "target_file": "services/inspection/src/adapters/bpc/detect_registry.py",
      "input_type": "tab bolt mask plus registered XYZ",
      "output_type": "base_tab washer_top head_top and height fields",
      "acceptance": "matches tab_bolt_height_fields production fields"
    },
    {
      "name": "CT_BPC_LabelRecognition",
      "target_file": "services/inspection/src/adapters/bpc/v16_label_adapter.py",
      "input_type": "configured v16 RGB or RGBA frame",
      "output_type": "LabelResult or None",
      "acceptance": "MODBUS_LABEL_VIEW_ID gates decode and segmentation is ROI helper only"
    },
    {
      "name": "CT_BPC_RecipeOptIn",
      "target_file": "services/inspection/src/adapters/bpc/pipeline_runner.py",
      "input_type": "RecipeV2 yaml stage",
      "output_type": "feature inspection result",
      "acceptance": "segmentation path is opt-in and classical fallback remains available"
    }
